{
  "extends": "@opentab/config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "~/drizzle/*": ["./drizzle/*"]
    },
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "allowJs": true,
    "rootDirs": [".", "./.react-router/types"],
    "types": ["vite/client", "react-router"]
  },
  "include": [
    "app/**/*",
    "drizzle/**/*",
    "workers/**/*",
    "react-router.config.ts",
    "vite.config.ts",
    "drizzle.config.ts",
    "alchemy.run.ts",
    "worker-configuration.d.ts",
    ".react-router/types/**/*"
  ]
}
