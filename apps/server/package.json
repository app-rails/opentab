{
  "name": "@opentab/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest run",
    "db:migrate": "better-auth migrate"
  },
  "dependencies": {
    "@hono/node-server": "^2",
    "@hono/trpc-server": "^0.4.2",
    "@opentab/api": "workspace:^",
    "@opentab/auth": "workspace:^",
    "@opentab/db": "workspace:^",
    "@opentab/shared": "workspace:*",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.6.10",
    "hono": "^4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@opentab/config": "workspace:^",
    "@types/node": "^25.9.0",
    "tsx": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
